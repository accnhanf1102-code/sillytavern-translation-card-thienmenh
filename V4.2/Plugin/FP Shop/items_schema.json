{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Items Schema",
  "description": "Schema dành cho tệp tin items.json trong hệ thống FP Shop",
  "type": "object",
  "required": ["Items"],
  "properties": {
    "Items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "cost", "type", "tag", "rarity", "quantity", "effect", "description"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Tên của vật phẩm"
          },
          "cost": {
            "type": "integer",
            "minimum": 0,
            "description": "Giá mua vật phẩm bằng FP"
          },
          "type": {
            "type": "string",
            "description": "Loại vật phẩm (Tiêu hao, Nhạc cụ, Trang phục, Khác, v.v.)"
          },
          "tag": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Các nhãn mô tả đặc tính hoặc công dụng của vật phẩm"
          },
          "rarity": {
            "type": "string",
            "enum": ["Thần thoại", "Huyền thoại", "Hiếm", "Thông thường"],
            "description": "Độ hiếm của vật phẩm"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Số lượng vật phẩm khi mua một lần"
          },
          "effect": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "Danh sách các hiệu ứng khi sử dụng vật phẩm. Key là tên hiệu ứng, Value là mô tả."
          },
          "description": {
            "type": "string",
            "description": "Mô tả chi tiết về vật phẩm"
          },
          "roast": {
            "type": "string",
            "description": "Đánh giá của hệ thống về vật phẩm"
          }
        }
      }
    }
  }
}
